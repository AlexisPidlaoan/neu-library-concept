rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Hardcoded Super Admin check with case-insensitive support for safety
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email.matches('(?i)alexis.pidlaoan@neu.edu.ph') ||
        request.auth.token.email.matches('(?i)pampa4858@gmail.com') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isAdmin() {
      return isSuperAdmin();
    }

    // --- Collection Rules ---

    match /admins/{userId} {
      allow get: if isSignedIn();
      allow create, update, delete: if isAdmin() || (isSignedIn() && (request.auth.token.email.matches('(?i)alexis.pidlaoan@neu.edu.ph') || request.auth.token.email.matches('(?i)pampa4858@gmail.com')));
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isSignedIn(); 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /colleges/{collegeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /visits/{visitId} {
      allow create: if isSignedIn();
      allow read, list: if isAdmin() || (
        isSignedIn() && (
          resource.data.userId == request.auth.uid || 
          (request.auth.token.email != null && resource.data.userEmail == request.auth.token.email)
        )
      );
      allow update, delete: if isAdmin();
    }

    // Secondary path match for complex queries
    match /{path=**}/visits/{visitId} {
       allow read, list: if isAdmin() || (
        isSignedIn() && (
          resource.data.userId == request.auth.uid || 
          (request.auth.token.email != null && resource.data.userEmail == request.auth.token.email)
        )
      );
    }
  }
}
