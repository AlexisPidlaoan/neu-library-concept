
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU Library Security Rules
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Check if user exists in the explicit roles_admin collection
      // OR if their user document has the 'admin' role
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn(); // Allow profile check
      allow list: if isAdmin() || (isSignedIn() && (request.query.limit == null || request.query.limit <= 100));
      allow create: if isSignedIn();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }

    match /colleges/{collegeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /visits/{visitId} {
      // Allow reading if the visitor is an admin OR if the record belongs to them.
      // We check userId in data for ownership.
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      // Allow listing for admins OR filtered by studentId/userId for current user
      allow list: if isAdmin() || (isSignedIn() && (request.query.limit == null || request.query.limit <= 100)); 
      
      // Allow creation for any signed-in student
      allow create: if isSignedIn();
      
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
