
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * StudyFlow Security Rules
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100);
      allow create: if isSignedIn(); // Allow profile creation
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }

    match /colleges/{collegeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /visits/{visitId} {
      allow get: if isAdmin() || (resource != null && resource.data.userId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100); 
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
