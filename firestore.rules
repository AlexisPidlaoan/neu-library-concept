rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Bootstrap Admin check for initial setup and system maintenance
    function isHardcodedAdmin() {
      return isSignedIn() && (
        request.auth.uid == '1t6xZ846ruWwhzwk7owwlhAP5142' ||
        request.auth.uid == 'm9USWS5C0seJ7oUIV3t65yxVjrv1' ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'alexis.pidlaoan@neu.edu.ph') ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'pampa4858@gmail.com') ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'admin@neu.edu.ph') ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'jcesperanza@neu.edu.ph')
      );
    }

    // Comprehensive Admin check
    function isAdmin() {
      return isHardcodedAdmin() || 
             exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.lower() == 'admin');
    }

    // --- Collection Rules ---

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn(); 
      allow create: if isSignedIn(); 
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /colleges/{collegeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /visits/{visitId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (
        isSignedIn() && (
          resource.data.userId == request.auth.uid || 
          (request.auth.token.email != null && resource.data.userEmail == request.auth.token.email)
        )
      );
      allow update, delete: if isAdmin();
    }

    // Allow collection group reads for admins or owners
    match /{path=**}/visits/{visitId} {
       allow read: if isAdmin() || (
        isSignedIn() && (
          resource.data.userId == request.auth.uid || 
          (request.auth.token.email != null && request.auth.token.email == resource.data.userEmail)
        )
      );
    }
  }
}
