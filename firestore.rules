rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Hardcoded Super Admin check to prevent lockouts
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "alexis.pidlaoan@neu.edu.ph" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isAdmin() {
      return isSuperAdmin();
    }

    // --- Collection Rules ---

    match /admins/{userId} {
      allow get: if isSignedIn();
      // Allow the specific super admin email to bootstrap the admin collection
      allow create, update, delete: if isAdmin() || (isSignedIn() && request.auth.token.email == "alexis.pidlaoan@neu.edu.ph");
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /colleges/{collegeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /visits/{visitId} {
      // Allow create for any signed in user
      allow create: if isSignedIn();
      
      // Allow read (get/list) if admin OR if the record belongs to the user
      allow read: if isAdmin() || (
        isSignedIn() && (
          resource.data.userId == request.auth.uid || 
          (request.auth.token.email != null && resource.data.userEmail == request.auth.token.email)
        )
      );
      
      // Only admins can modify or remove logs
      allow update, delete: if isAdmin();
    }

    // Secondary path match for complex queries
    match /{path=**}/visits/{visitId} {
       allow read: if isAdmin() || (
        isSignedIn() && (
          resource.data.userId == request.auth.uid || 
          (request.auth.token.email != null && resource.data.userEmail == request.auth.token.email)
        )
      );
    }
  }
}