
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the NEU Library system, including students and administrators.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity (Google UID)."
        },
        "email": {
          "type": "string",
          "description": "Institutional email address (@neu.edu.ph).",
          "format": "email"
        },
        "displayName": {
          "type": "string",
          "description": "The full name of the user."
        },
        "studentId": {
          "type": "string",
          "description": "The formatted student ID (XX-XXXXX-XXX)."
        },
        "role": {
          "type": "string",
          "enum": ["student", "admin"],
          "description": "User role within the system."
        },
        "isBlocked": {
          "type": "boolean",
          "description": "Indicates if the user is blocked from entry."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "displayName",
        "role",
        "isBlocked"
      ]
    },
    "Visit": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Visit",
      "type": "object",
      "description": "Records a single library visit entry.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "userName": {
          "type": "string"
        },
        "userEmail": {
          "type": "string"
        },
        "college": {
          "type": "string"
        },
        "program": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "timestamp": {
          "type": "object",
          "description": "Firestore server timestamp."
        }
      },
      "required": ["userId", "userName", "college", "purpose", "timestamp"]
    }
  },
  "auth": {
    "providers": [
      "google.com",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "User profiles for students and admins."
        }
      },
      {
        "path": "/admins/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Role-marker collection for admin privileges."
        }
      },
      {
        "path": "/visits/{visitId}",
        "definition": {
          "entityName": "Visit",
          "schema": {
            "$ref": "#/backend/entities/Visit"
          },
          "description": "Global log of all library visits."
        }
      },
      {
        "path": "/colleges/{collegeId}",
        "definition": {
          "entityName": "College",
          "description": "List of available university departments."
        }
      }
    ]
  }
}
